# Copy to terraform.tfvars and fill in your values.
# Do not commit terraform.tfvars if it contains secrets.

resource_group_name  = "rg-nedora-prod"
static_web_app_name  = "swa-nedora-landing-prod"
storage_account_name = "stnedoralandingprod"
location             = "westeurope"
sku_tier             = "Free"
sku_size             = "Free"
contact_table_name   = "ContactSubmissions"

# Optional: connect GitHub for built-in SWA deployments
# repository_url    = "https://github.com/your-org/nedora-landing"
# repository_branch = "main"
# repository_token  = "<github-pat-with-repo-scope>"

tags = {
  project    = "nedora-landing"
  managed_by = "terraform"
  environment = "prod"
}
